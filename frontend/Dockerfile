FROM node:20-alpine

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ARG NEXT_PUBLIC_COGNITO_DOMAIN=
ARG NEXT_PUBLIC_COGNITO_CLIENT_ID=
ARG NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000
ARG NEXT_PUBLIC_USE_COGNITO_HOSTED_LOGOUT=false
ARG NEXT_PUBLIC_COGNITO_LOGOUT_URI=
ARG REQUIRE_COGNITO_ENV=false

ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_COGNITO_DOMAIN=${NEXT_PUBLIC_COGNITO_DOMAIN}
ENV NEXT_PUBLIC_COGNITO_CLIENT_ID=${NEXT_PUBLIC_COGNITO_CLIENT_ID}
ENV NEXT_PUBLIC_COGNITO_REDIRECT_URI=${NEXT_PUBLIC_COGNITO_REDIRECT_URI}
ENV NEXT_PUBLIC_USE_COGNITO_HOSTED_LOGOUT=${NEXT_PUBLIC_USE_COGNITO_HOSTED_LOGOUT}
ENV NEXT_PUBLIC_COGNITO_LOGOUT_URI=${NEXT_PUBLIC_COGNITO_LOGOUT_URI}

RUN test -n "$NEXT_PUBLIC_API_BASE_URL" \
  && test -n "$NEXT_PUBLIC_COGNITO_REDIRECT_URI" \
  && if [ "$REQUIRE_COGNITO_ENV" = "true" ]; then \
       test -n "$NEXT_PUBLIC_COGNITO_DOMAIN" && test -n "$NEXT_PUBLIC_COGNITO_CLIENT_ID"; \
     fi

COPY frontend/package*.json ./
RUN npm ci --include=dev

COPY frontend ./

RUN npm run build

ENV NODE_ENV=production

RUN chmod +x /app/entrypoint.sh

EXPOSE 3000

ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["npx", "next", "start", "--hostname", "0.0.0.0", "--port", "3000"]
